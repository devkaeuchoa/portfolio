---
import Layout from '../../layouts/Layout.astro';
import SduiPage from '../../components/sdui/SduiPage.astro';
import { profile } from '../../data/resume';

const lang = 'en' as const;
---

<Layout
	lang={lang}
	title={`Server-Driven UI — ${profile.name}`}
	description="A Server-Driven UI demo: JSON interpreted at build time and rendered with real components."
>
	<main>
		<SduiPage lang={lang} />
	</main>
</Layout>
