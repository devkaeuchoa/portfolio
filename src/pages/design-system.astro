---
import Layout from '../layouts/Layout.astro';
import DesignSystemPage from '../components/design-system/DesignSystemPage.astro';
import { profile } from '../data/resume';

const lang = 'pt' as const;
---

<Layout
	lang={lang}
	title={`Design System — ${profile.name}`}
	description="Reconstrução funcional de uma biblioteca de componentes acessíveis, feita nativamente em Astro."
>
	<main>
		<DesignSystemPage lang={lang} />
	</main>
</Layout>
