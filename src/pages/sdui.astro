---
import Layout from '../layouts/Layout.astro';
import SduiPage from '../components/sdui/SduiPage.astro';
import { profile } from '../data/resume';

const lang = 'pt' as const;
---

<Layout
	lang={lang}
	title={`Server-Driven UI — ${profile.name}`}
	description="Demonstração de Server-Driven UI: JSON interpretado em tempo de build e renderizado com componentes reais."
>
	<main>
		<SduiPage lang={lang} />
	</main>
</Layout>
