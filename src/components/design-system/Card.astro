---
interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<div class="card">
	{title && <h4>{title}</h4>}
	<div class="body">
		<slot />
	</div>
	{Astro.slots.has('footer') && (
		<div class="footer">
			<slot name="footer" />
		</div>
	)}
</div>

<style>
	.card {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 12px;
		padding: 1rem 1.1rem;
		max-width: 22rem;
	}

	h4 {
		margin: 0 0 0.5rem;
		font-size: 1rem;
	}

	.body {
		color: var(--color-muted);
		font-size: 0.9rem;
	}

	.footer {
		margin-top: 0.85rem;
		padding-top: 0.75rem;
		border-top: 1px solid var(--color-border);
	}
</style>
