---
import { profile, content, type Lang } from '../data/resume';
import WebDevIllustration from './WebDevIllustration.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = content[lang];
const overline = { pt: 'Olá, eu sou', en: "Hi, I'm", es: 'Hola, soy' }[lang];
const educationHeading = { pt: 'Formação', en: 'Education', es: 'Formación' }[lang];
---

<section id="sobre" class="hero-section">
	<div class="hero">
		<div class="hero-text">
			<p class="overline">{overline}</p>
			<h1>@devkaeuchoa</h1>
			<p class="subtitle">Kaê Uchôa</p>
			<p class="title">{t.title} · {t.location}</p>
			<p class="tagline">{t.tagline}</p>
			<p class="summary summary-short">{t.summaryShort}</p>
			<p class="summary summary-full">{t.summary}</p>
			<p class="links">
				<a href={`mailto:${profile.email}`}>{profile.email}</a>
				<a href={profile.links.github} target="_blank" rel="noreferrer">GitHub</a>
				<a href={profile.links.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
			</p>
			<div class="education">
				<p class="education-heading">{educationHeading}</p>
				<div class="education-list">
					{
						t.education.map((item) => (
							<div class="education-item">
								<span class="cap-icon" aria-hidden="true">
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
										<path d="M12 4 L22 8 L12 12 L2 8 Z" />
										<path d="M6 10 V15 C6 16.5 8.5 18 12 18 C15.5 18 18 16.5 18 15 V10" />
										<path d="M22 8 V14" />
									</svg>
								</span>
								<span class="education-text">
									<strong>{item.degree}</strong>
									<span class="education-meta">
										{item.institution} · {item.period}
									</span>
								</span>
							</div>
						))
					}
				</div>
			</div>
		</div>
		<div class="hero-art">
			<WebDevIllustration />
		</div>
	</div>
</section>

<style>
	.hero-section {
		width: 100%;
		padding: 3rem 1.5rem 1rem;
	}

	.hero {
		max-width: 1200px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
		align-items: center;
	}

	.overline {
		margin: 0;
		color: var(--color-accent);
		font-size: 0.9rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	h1 {
		margin: 0.2rem 0 0;
		font-size: 2.4rem;
	}

	.subtitle {
		margin: 0.2rem 0 0;
		font-size: 1.15rem;
		font-weight: 600;
		color: var(--color-text);
	}

	.title {
		color: var(--color-muted);
		margin: 0.3rem 0 0;
	}

	.tagline {
		margin: 1rem 0 0;
		font-size: 1.15rem;
	}

	.summary {
		margin: 0.75rem 0 0;
		color: var(--color-muted);
		max-width: 60ch;
	}

	.summary-full {
		display: none;
	}

	.links {
		margin: 1.25rem 0 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		font-size: 0.9rem;
	}

	.links a {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 999px;
		padding: 0.3rem 0.9rem;
		text-decoration: none;
	}

	.links a:hover {
		border-color: var(--color-accent);
	}

	.hero-art {
		display: flex;
		justify-content: center;
	}

	.education {
		margin-top: 1.75rem;
	}

	.education-heading {
		margin: 0 0 0.6rem;
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-muted);
	}

	.education-list {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.education-item {
		display: flex;
		align-items: flex-start;
		gap: 0.65rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 10px;
		padding: 0.6rem 0.85rem;
		transition: border-color 0.15s ease;
	}

	.education-item:hover {
		border-color: var(--color-accent);
	}

	.cap-icon {
		flex-shrink: 0;
		color: var(--color-accent);
		margin-top: 0.15rem;
	}

	.cap-icon svg {
		width: 1.15rem;
		height: 1.15rem;
	}

	.education-text {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
		font-size: 0.85rem;
	}

	.education-meta {
		color: var(--color-muted);
		font-size: 0.78rem;
	}

	@media (min-width: 720px) {
		.hero {
			grid-template-columns: 1.15fr 0.85fr;
		}

		.hero-art {
			justify-content: flex-end;
		}

		.summary-short {
			display: none;
		}

		.summary-full {
			display: block;
		}

		.education-list {
			flex-direction: row;
			flex-wrap: wrap;
		}

		.education-item {
			flex: 1 1 240px;
		}
	}
</style>
