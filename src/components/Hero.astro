---
import { profile, content, type Lang } from '../data/resume';
import HeroCarousel from './HeroCarousel.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = content[lang];
const overline = { pt: 'Olá, eu sou', en: "Hi, I'm", es: 'Hola, soy' }[lang];
---

<section id="sobre" class="hero-section">
	<div class="hero">
		<div class="hero-text">
			<p class="overline">{overline}</p>
			<h1>@devkaeuchoa</h1>
			<p class="subtitle">Kaê Uchôa</p>
			<p class="title">{t.title} · {t.location}</p>
		</div>
		<HeroCarousel lang={lang} />
	</div>
</section>

<style>
	.hero-section {
		width: 100%;
		padding: 3rem 1.5rem 1rem;
	}

	.hero {
		max-width: 1200px;
		margin: 0 auto;
	}

	.overline {
		margin: 0;
		color: var(--color-accent);
		font-size: 0.9rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	h1 {
		margin: 0.2rem 0 0;
		font-size: 2.4rem;
	}

	.subtitle {
		margin: 0.2rem 0 0;
		font-size: 1.15rem;
		font-weight: 600;
		color: var(--color-text);
	}

	.title {
		color: var(--color-muted);
		margin: 0.3rem 0 0;
	}
</style>
