---
import type { Lang } from '../data/resume';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const options: { lang: Lang; href: string; label: string }[] = [
  { lang: 'pt', href: '/', label: 'PT' },
  { lang: 'en', href: '/en/', label: 'EN' },
  { lang: 'es', href: '/es/', label: 'ES' },
];
---

<div class="lang-switcher" role="group" aria-label="Language">
	{
		options.map((option) =>
			option.lang === lang ? (
				<span class="lang-option is-current" aria-current="true">
					{option.label}
				</span>
			) : (
				<a class="lang-option" href={option.href}>
					{option.label}
				</a>
			)
		)
	}
</div>

<style>
	.lang-switcher {
		display: inline-flex;
		align-items: center;
		gap: 0.15rem;
		padding: 0.2rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		background: var(--color-surface);
	}

	.lang-option {
		font-size: 0.8rem;
		font-weight: 600;
		padding: 0.3rem 0.6rem;
		border-radius: 999px;
		text-decoration: none;
		color: var(--color-muted);
	}

	a.lang-option:hover {
		color: var(--color-text);
	}

	.lang-option.is-current {
		background: var(--color-accent);
		color: var(--color-bg);
	}
</style>
