<script>
	const root = document.querySelector<HTMLElement>('[data-locations-map]');
	const pins = Array.from(root?.querySelectorAll<SVGGElement>('.pin') ?? []);

	function entriesFor(pin: SVGGElement): { index: number }[] {
		return JSON.parse(pin.dataset.entries ?? '[]');
	}

	function rowFor(index: number): HTMLElement | null {
		return document.querySelector<HTMLElement>(`[data-toggle="${index}"]`)?.closest('.row') ?? null;
	}

	function refreshPinStates() {
		pins.forEach((pin) => {
			const isActive = entriesFor(pin).some((entry) => rowFor(entry.index)?.classList.contains('is-open'));
			pin.classList.toggle('is-active', isActive);
		});
	}

	pins.forEach((pin) => {
		const activate = () => {
			const indices = entriesFor(pin).map((entry) => entry.index);
			document.dispatchEvent(new CustomEvent('map-pin-select', { detail: { indices } }));
			refreshPinStates();
		};
		pin.addEventListener('click', activate);
		pin.addEventListener('keydown', (e) => {
			if (e.key === 'Enter' || e.key === ' ') {
				e.preventDefault();
				activate();
			}
		});
	});

	document.addEventListener('experience-row-toggle', () => refreshPinStates());

	refreshPinStates();
</script>

<style>
	.locations-map {
		width: 100%;
	}

	.map-wrap {
		width: 100%;
		max-width: 640px;
		margin: 0 auto;
		position: relative;
		background-image: radial-gradient(var(--color-border) 1px, transparent 1px);
		background-size: 14px 14px;
		border-radius: 12px;
	}

	.americas-map {
		width: 100%;
		height: auto;
		display: block;
	}

	.country {
		fill: rgba(var(--color-accent-rgb), 0.35);
		stroke: var(--color-bg);
		stroke-width: 1.2;
		stroke-linejoin: round;
	}

	.pin {
		cursor: pointer;
	}

	.pin-halo {
		fill: rgba(var(--color-accent-rgb), 0.2);
	}

	.pin-dot {
		fill: var(--color-accent);
	}

	.pin:hover .pin-halo,
	.pin:focus-visible .pin-halo {
		fill: rgba(var(--color-accent-rgb), 0.35);
	}

	.pin:focus-visible {
		outline: none;
	}

	.pin.is-active .pin-halo {
		fill: rgba(var(--color-selected-rgb), 0.45);
		r: 13;
	}

	.pin.is-active .pin-dot {
		fill: var(--color-selected);
		r: 7;
		filter: drop-shadow(0 0 3px rgba(var(--color-selected-rgb), 0.8));
	}
</style>
