---
import { content, type Lang } from '../data/resume';
import { locations, experienceLocations, project, type LocationKey } from '../data/locations';

interface Props {
  lang: Lang;
}

interface PinEntry {
  title: string;
  subtitle: string;
  period: string;
  index: number;
}

interface Pin {
  key: LocationKey;
  city: string;
  x: number;
  y: number;
  entries: PinEntry[];
}

const { lang } = Astro.props;
const t = content[lang];

const pinsByKey = new Map<LocationKey, Pin>();
t.experience.forEach((job, i) => {
  const key = experienceLocations[i];
  const loc = locations[key];
  if (!pinsByKey.has(key)) {
    const { x, y } = project(loc.lat, loc.lng);
    pinsByKey.set(key, { key, city: loc.city, x, y, entries: [] });
  }
  pinsByKey.get(key)!.entries.push({ title: job.role, subtitle: job.company, period: job.period, index: i });
});
const pins = Array.from(pinsByKey.values());

const mapAriaLabel = { pt: 'Mapa de localizações', en: 'Map of locations', es: 'Mapa de ubicaciones' }[lang];
---

