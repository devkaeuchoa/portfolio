---
import type { Lang } from '../../data/resume';
import Badge from '../design-system/Badge.astro';
import CodeSample from '../design-system/CodeSample.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const localePrefix = { pt: '', en: '/en', es: '/es' }[lang];
const backHref = `${base}${localePrefix}/`;
const sitemapHref = `${base}/sitemap-index.xml`;

const codeSamples = {
  canonical: `<link rel="canonical" href={canonicalUrl} />`,
  og: `<meta property="og:type" content="website" />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={pageDescription} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:locale" content={ogLocale} />`,
  jsonld: `<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: profile.name,
  url: Astro.site,
  sameAs: [profile.links.github, profile.links.linkedin],
  jobTitle: t.title,
})} />`,
  sitemap: `import sitemap from '@astrojs/sitemap';

export default defineConfig({
  site: 'https://devkaeuchoa.github.io',
  base: '/portfolio',
  integrations: [sitemap()],
});`,
};

const t = {
  pt: {
    intro: 'SEO',
    lead: 'Este portfólio inteiro roda com essas técnicas de verdade — não é uma página isolada de exemplo. Todo o head, o sitemap e os dados estruturados abaixo são os mesmos usados em cada página deste site.',
    back: '← Voltar ao portfólio',
    checklistHeading: 'Aplicado neste site',
    checklist: ['Canonical URL', 'Open Graph', 'JSON-LD (schema.org)', 'sitemap.xml'],
    canonicalTitle: 'Canonical URL',
    canonicalDesc: 'Cada página declara sua própria URL canônica, calculada a partir de Astro.site e Astro.url — evita conteúdo duplicado entre idiomas.',
    ogTitle: 'Open Graph',
    ogDesc: 'Título, descrição, URL e idioma corretos ao compartilhar qualquer página em redes sociais.',
    jsonldTitle: 'Dados estruturados (JSON-LD)',
    jsonldDesc: 'Schema.org Person embutido no <head>, ajudando buscadores a entender quem é o dono do site.',
    sitemapTitle: 'sitemap.xml real',
    sitemapDesc: 'Gerado automaticamente no build pelo @astrojs/sitemap, listando todas as páginas e idiomas.',
    sitemapLink: 'Ver sitemap.xml gerado →',
  },
  en: {
    intro: 'SEO',
    lead: "This whole portfolio runs on these techniques for real — not an isolated example page. The entire head, sitemap, and structured data below are the same ones used on every page of this site.",
    back: '← Back to portfolio',
    checklistHeading: 'Applied on this site',
    checklist: ['Canonical URL', 'Open Graph', 'JSON-LD (schema.org)', 'sitemap.xml'],
    canonicalTitle: 'Canonical URL',
    canonicalDesc: 'Every page declares its own canonical URL, computed from Astro.site and Astro.url — avoids duplicate content across languages.',
    ogTitle: 'Open Graph',
    ogDesc: 'Correct title, description, URL, and locale when sharing any page on social media.',
    jsonldTitle: 'Structured data (JSON-LD)',
    jsonldDesc: 'Schema.org Person embedded in the <head>, helping search engines understand who owns the site.',
    sitemapTitle: 'Real sitemap.xml',
    sitemapDesc: 'Generated automatically at build time by @astrojs/sitemap, listing every page and locale.',
    sitemapLink: 'View the generated sitemap.xml →',
  },
  es: {
    intro: 'SEO',
    lead: 'Todo este portafolio funciona con estas técnicas de verdad, no es una página de ejemplo aislada. Todo el head, el sitemap y los datos estructurados de abajo son los mismos que se usan en cada página de este sitio.',
    back: '← Volver al portafolio',
    checklistHeading: 'Aplicado en este sitio',
    checklist: ['Canonical URL', 'Open Graph', 'JSON-LD (schema.org)', 'sitemap.xml'],
    canonicalTitle: 'Canonical URL',
    canonicalDesc: 'Cada página declara su propia URL canónica, calculada a partir de Astro.site y Astro.url — evita contenido duplicado entre idiomas.',
    ogTitle: 'Open Graph',
    ogDesc: 'Título, descripción, URL e idioma correctos al compartir cualquier página en redes sociales.',
    jsonldTitle: 'Datos estructurados (JSON-LD)',
    jsonldDesc: 'Schema.org Person embebido en el <head>, ayudando a los buscadores a entender quién es el dueño del sitio.',
    sitemapTitle: 'sitemap.xml real',
    sitemapDesc: 'Generado automáticamente en el build por @astrojs/sitemap, listando todas las páginas e idiomas.',
    sitemapLink: 'Ver el sitemap.xml generado →',
  },
}[lang];
---

<div class="section-breakout">
<div class="section-breakout-inner">
<article class="seo-page">
	<a href={backHref} class="back-link">{t.back}</a>
	<h1>{t.intro}</h1>
	<p class="lead">{t.lead}</p>

	<section>
		<h2>{t.checklistHeading}</h2>
		<div class="checklist">
			{t.checklist.map((item) => <Badge tone="accent">✓ {item}</Badge>)}
		</div>
	</section>

	<section>
		<h2>{t.canonicalTitle}</h2>
		<p class="description">{t.canonicalDesc}</p>
		<CodeSample code={codeSamples.canonical} />
	</section>

	<section>
		<h2>{t.ogTitle}</h2>
		<p class="description">{t.ogDesc}</p>
		<CodeSample code={codeSamples.og} />
	</section>

	<section>
		<h2>{t.jsonldTitle}</h2>
		<p class="description">{t.jsonldDesc}</p>
		<CodeSample code={codeSamples.jsonld} />
	</section>

	<section>
		<h2>{t.sitemapTitle}</h2>
		<p class="description">{t.sitemapDesc}</p>
		<CodeSample code={codeSamples.sitemap} />
		<a href={sitemapHref} class="sitemap-link">{t.sitemapLink}</a>
	</section>
</article>
</div>
</div>

<style>
	.section-breakout {
		width: 100vw;
		max-width: 100vw;
		margin-left: calc(50% - 50vw);
		margin-right: calc(50% - 50vw);
	}

	.section-breakout-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	.seo-page {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.back-link {
		font-size: 0.9rem;
		align-self: flex-start;
	}

	h1 {
		margin: 0;
	}

	.lead {
		margin: 0;
		color: var(--color-muted);
		max-width: 40rem;
	}

	h2 {
		margin: 0 0 0.6rem;
		font-size: 1.05rem;
	}

	.description {
		margin: 0 0 0.75rem;
		color: var(--color-muted);
		font-size: 0.9rem;
	}

	.checklist {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.sitemap-link {
		display: inline-block;
		margin-top: 0.6rem;
		font-size: 0.85rem;
		font-weight: 600;
	}

</style>
