---
import { content, type Lang } from '../data/resume';
import { techIcons } from '../data/techIcons';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = content[lang];
const heading = { pt: 'Experiência', en: 'Experience', es: 'Experiencia' }[lang];

function extractYears(period: string): string {
  const years = period.match(/\d{4}/g) ?? [];
  const isOngoing = /atual|present|actualidad/i.test(period);
  const label = { pt: 'atual', en: 'Present', es: 'actualidad' }[lang];

  if (isOngoing) return years.length ? `${years[0]} — ${label}` : label;
  if (years.length >= 2 && years[0] !== years[1]) return `${years[0]} — ${years[1]}`;
  return years[0] ?? period;
}

const toggleLabel = { pt: 'Mostrar detalhes de', en: 'Show details for', es: 'Mostrar detalles de' }[lang];
const ctaLabel = { pt: 'Ir para o site', en: 'Go to website', es: 'Ir al sitio web' }[lang];
const closeLabel = { pt: 'Fechar', en: 'Close', es: 'Cerrar' }[lang];
const expandAllLabel = { pt: 'Ver todos', en: 'View all', es: 'Ver todos' }[lang];
const collapseAllLabel = { pt: 'Recolher todos', en: 'Collapse all', es: 'Contraer todos' }[lang];
---

<section id="experiencia">
	<div class="section-header">
		<h2>{heading}</h2>
		<button type="button" class="toggle-all" data-toggle-all data-expand-label={expandAllLabel} data-collapse-label={collapseAllLabel}>
			{expandAllLabel}
		</button>
	</div>
	<div class="timeline">
		{
			t.experience.map((job, i) => {
				const isCurrent = /atual|present|actualidad/i.test(job.period);
				const descId = `exp-desc-${lang}-${i}`;
				return (
					<div class:list={['row', isCurrent && 'is-open']}>
						<span class="year">{extractYears(job.period)}</span>
						<span class="dot-col">
							<span
								class="dot"
								data-toggle={i}
								role="button"
								tabindex="0"
								aria-expanded={isCurrent ? 'true' : 'false'}
								aria-controls={descId}
								aria-label={`${toggleLabel} ${job.role} · ${job.company}`}
							/>
						</span>
						<div class="content">
							<div class="stack-row" role="list">
								{job.stack.map((key) => {
									const icon = techIcons[key];
									return (
										<button
											type="button"
											class="tech-pill"
											data-tech-toggle
											aria-label={icon.label}
											role="listitem"
										>
											<svg class="tech-icon" viewBox="0 0 24 24" aria-hidden="true">
												<path d={icon.path} />
											</svg>
											<span class="tech-label">{icon.label}</span>
										</button>
									);
								})}
							</div>
							<h3 class="role-company">
								<span
									class="role-text"
									data-toggle={i}
									role="button"
									tabindex="0"
									aria-expanded={isCurrent ? 'true' : 'false'}
									aria-controls={descId}
									aria-label={`${toggleLabel} ${job.role} · ${job.company}`}
								>
									{job.role}
								</span>
								{' · '}
								{job.companySummary ? (
									<span class="company-wrap">
										<a
											class="company-link"
											href={job.companyUrl}
											target="_blank"
											rel="noreferrer"
											data-company-trigger={i}
											aria-describedby={`company-pop-${lang}-${i}`}
										>
											{job.company}
										</a>
										<span class="company-backdrop" data-company-backdrop={i} />
										<span
											class="company-popover"
											id={`company-pop-${lang}-${i}`}
											role="dialog"
											aria-label={job.company}
										>
											<span class="company-popover-arrow" aria-hidden="true" />
											<button
												type="button"
												class="company-close"
												data-company-close={i}
												aria-label={closeLabel}
											>
												×
											</button>
											<p>{job.companySummary}</p>
											<a
												class="company-cta"
												href={job.companyUrl}
												target="_blank"
												rel="noreferrer"
											>
												{ctaLabel}
											</a>
										</span>
									</span>
								) : (
									<a
										class="company-link"
										href={job.companyUrl}
										target="_blank"
										rel="noreferrer"
									>
										{job.company}
									</a>
								)}
								<span class="chevron" aria-hidden="true">
									›
								</span>
							</h3>
							<p id={descId} class="description" hidden={!isCurrent}>
								{job.description}
							</p>
						</div>
					</div>
				);
			})
		}
	</div>
</section>

<script>
	const toggles = document.querySelectorAll<HTMLElement>('[data-toggle]');

	toggles.forEach((el) => {
		const group = document.querySelectorAll<HTMLElement>(
			`[data-toggle="${el.dataset.toggle}"]`
		);
		const descId = el.getAttribute('aria-controls');
		const desc = descId ? document.getElementById(descId) : null;
		const row = el.closest<HTMLElement>('.row');
		if (!desc || !row) return;

		const toggle = () => {
			const expanded = row.classList.toggle('is-open');
			desc.hidden = !expanded;
			group.forEach((t) => t.setAttribute('aria-expanded', String(expanded)));
		};

		el.addEventListener('click', toggle);
		el.addEventListener('keydown', (e) => {
			if (e.key === 'Enter' || e.key === ' ') {
				e.preventDefault();
				toggle();
			}
		});
	});

	const toggleAllBtn = document.querySelector<HTMLButtonElement>('[data-toggle-all]');
	const rows = document.querySelectorAll<HTMLElement>('.timeline .row');

	if (toggleAllBtn) {
		const expandLabel = toggleAllBtn.dataset.expandLabel ?? '';
		const collapseLabel = toggleAllBtn.dataset.collapseLabel ?? '';

		const setAllRows = (open: boolean) => {
			rows.forEach((row) => {
				row.classList.toggle('is-open', open);
				const desc = row.querySelector<HTMLElement>('.description');
				if (desc) desc.hidden = !open;
				row.querySelectorAll<HTMLElement>('[data-toggle]').forEach((t) => {
					t.setAttribute('aria-expanded', String(open));
				});
			});
			toggleAllBtn.textContent = open ? collapseLabel : expandLabel;
			toggleAllBtn.setAttribute('aria-expanded', String(open));
		};

		toggleAllBtn.addEventListener('click', () => {
			const anyClosed = Array.from(rows).some((row) => !row.classList.contains('is-open'));
			setAllRows(anyClosed);
		});
	}

	// Dispositivos sem hover "de verdade" (touch) precisam de um clique para
	// revelar o popover/bottom sheet, já que não há :hover para acioná-lo.
	const hasRealHover = () => window.matchMedia('(hover: hover) and (pointer: fine)').matches;
	const isSheetViewport = () => window.matchMedia('(max-width: 640px)').matches;

	const closeAllCompanyPopovers = () => {
		document.querySelectorAll<HTMLElement>('.company-wrap.open').forEach((wrap) => {
			wrap.classList.remove('open');
		});
		document.body.classList.remove('scroll-locked');
	};

	document.querySelectorAll<HTMLAnchorElement>('[data-company-trigger]').forEach((link) => {
		const wrap = link.closest<HTMLElement>('.company-wrap');
		if (!wrap) return;

		link.addEventListener('click', (e) => {
			if (!hasRealHover()) {
				e.preventDefault();
				closeAllCompanyPopovers();
				wrap.classList.add('open');
				if (isSheetViewport()) {
					document.body.classList.add('scroll-locked');
				}
			}
		});
	});

	document.querySelectorAll<HTMLElement>('[data-company-backdrop]').forEach((backdrop) => {
		backdrop.addEventListener('click', closeAllCompanyPopovers);
	});

	document.querySelectorAll<HTMLElement>('[data-company-close]').forEach((btn) => {
		btn.addEventListener('click', closeAllCompanyPopovers);
	});

	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape') closeAllCompanyPopovers();
	});

	document.addEventListener('click', (e) => {
		document.querySelectorAll<HTMLElement>('.company-wrap.open').forEach((wrap) => {
			if (!wrap.contains(e.target as Node)) {
				wrap.classList.remove('open');
				document.body.classList.remove('scroll-locked');
			}
		});
	});

	const techPills = document.querySelectorAll<HTMLElement>('[data-tech-toggle]');

	techPills.forEach((pill) => {
		pill.addEventListener('click', () => {
			const wasExpanded = pill.classList.contains('expanded');
			techPills.forEach((p) => p.classList.remove('expanded'));
			pill.classList.toggle('expanded', !wasExpanded);
		});
	});
</script>

<style>
	.section-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.section-header h2 {
		margin: 0;
	}

	.toggle-all {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 999px;
		padding: 0.35rem 0.9rem;
		font-size: 0.85rem;
		color: var(--color-text);
		cursor: pointer;
		white-space: nowrap;
	}

	.toggle-all:hover,
	.toggle-all:focus-visible {
		border-color: var(--color-accent);
		outline: none;
	}

	.timeline {
		--stack-offset: 2.15rem;
		display: grid;
		grid-template-columns: max-content 1.5rem 1fr;
		column-gap: 1rem;
		row-gap: 0;
		list-style: none;
		margin: 2rem 0 0;
		padding: 0;
	}

	.row {
		display: contents;
	}

	.year {
		text-align: right;
		white-space: nowrap;
		color: var(--color-muted);
		font-size: 0.9rem;
		padding-top: calc(var(--stack-offset) + 0.3rem);
	}

	.dot-col {
		position: relative;
		display: flex;
		justify-content: center;
	}

	.dot-col::before {
		content: '';
		position: absolute;
		top: 0;
		bottom: 0;
		width: 2px;
		background: var(--color-border);
	}

	.row:first-child .dot-col::before {
		top: calc(var(--stack-offset) + 0.675rem);
	}

	.row:last-child .dot-col::before {
		bottom: calc(100% - (var(--stack-offset) + 0.675rem));
	}

	.dot {
		width: 0.65rem;
		height: 0.65rem;
		margin-top: calc(var(--stack-offset) + 0.35rem);
		border-radius: 50%;
		background: var(--color-accent);
		position: relative;
		z-index: 1;
		cursor: pointer;
		transition: transform 0.15s ease, box-shadow 0.15s ease;
	}

	.row.is-open .dot {
		width: 0.8rem;
		height: 0.8rem;
		margin-top: calc(var(--stack-offset) + 0.3rem);
		box-shadow: 0 0 0 3px rgba(var(--color-accent-rgb), 0.25);
	}

	.dot:hover,
	.dot:focus-visible {
		transform: scale(1.35);
		box-shadow: 0 0 0 4px rgba(var(--color-accent-rgb), 0.3);
		outline: none;
	}

	.content {
		padding-bottom: 2rem;
	}

	.row:last-child .content {
		padding-bottom: 0;
	}

	.stack-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-bottom: 0.6rem;
	}

	.tech-pill {
		display: inline-flex;
		align-items: center;
		height: 1.55rem;
		padding: 0 0.35rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 999px;
		color: var(--color-muted);
		cursor: pointer;
		overflow: hidden;
		transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
	}

	.tech-icon {
		width: 0.95rem;
		height: 0.95rem;
		flex-shrink: 0;
		fill: currentColor;
	}

	.tech-label {
		max-width: 0;
		opacity: 0;
		white-space: nowrap;
		overflow: hidden;
		font-size: 0.72rem;
		font-weight: 600;
		transition: max-width 0.2s ease, opacity 0.2s ease, margin-left 0.2s ease;
	}

	.tech-pill:focus-visible {
		color: var(--color-text);
		border-color: var(--color-accent);
		outline: none;
	}

	.tech-pill:focus-visible .tech-label,
	.tech-pill.expanded .tech-label {
		max-width: 140px;
		opacity: 1;
		margin-left: 0.35rem;
	}

	.tech-pill.expanded {
		color: var(--color-text);
		border-color: var(--color-accent);
	}

	@media (hover: hover) and (pointer: fine) {
		.tech-pill:hover {
			color: var(--color-text);
			border-color: var(--color-accent);
		}

		.tech-pill:hover .tech-label {
			max-width: 140px;
			opacity: 1;
			margin-left: 0.35rem;
		}
	}

	h3.role-company {
		margin: 0;
		font-size: 1.05rem;
		display: inline-flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.35rem;
		width: fit-content;
	}

	.role-text {
		cursor: pointer;
		color: var(--color-text);
	}

	.row.is-open .role-text {
		font-weight: 800;
		opacity: 1;
	}

	.row:not(.is-open) .role-text {
		font-weight: 400;
		opacity: 0.9;
	}

	.role-text:hover,
	.role-text:focus-visible {
		text-decoration: underline;
		opacity: 1;
		outline: none;
	}

	.company-link {
		font-weight: 700;
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.company-link:hover {
		color: var(--color-text);
	}

	.company-link:focus-visible {
		color: var(--color-text);
		text-decoration: none;
	}

	.company-wrap {
		position: relative;
		display: inline-flex;
	}

	.company-backdrop {
		display: none;
	}

	.company-popover {
		position: absolute;
		bottom: calc(100% + 10px);
		left: 50%;
		transform: translateX(-50%) translateY(4px);
		width: 280px;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 10px;
		padding: 2rem 1.25rem 1.25rem;
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transition: opacity 0.15s ease, transform 0.15s ease;
		z-index: 20;
		font-size: 0.85rem;
		font-weight: 400;
		color: var(--color-text);
	}

	.company-popover p {
		margin: 0 0 1rem;
		color: var(--color-muted);
	}

	.company-popover-arrow {
		position: absolute;
		bottom: -5px;
		left: 50%;
		transform: translateX(-50%) rotate(45deg);
		width: 10px;
		height: 10px;
		background: var(--color-surface);
		border-right: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
	}

	.company-close {
		position: absolute;
		top: 0.35rem;
		right: 0.35rem;
		background: none;
		border: none;
		color: var(--color-muted);
		font-size: 1.4rem;
		line-height: 1;
		cursor: pointer;
		padding: 0.4rem;
		z-index: 1;
	}

	.company-cta {
		display: block;
		width: 100%;
		box-sizing: border-box;
		text-align: center;
		background: var(--color-accent);
		color: var(--color-bg);
		font-weight: 700;
		text-decoration: none;
		border-radius: 999px;
		padding: 0.5rem 0.9rem;
		font-size: 0.8rem;
	}

	.company-wrap.open .company-popover {
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
		transform: translateX(-50%) translateY(0);
	}

	@media (hover: hover) and (pointer: fine) {
		.company-wrap:hover .company-popover,
		.company-wrap:focus-within .company-popover {
			opacity: 1;
			visibility: visible;
			pointer-events: auto;
			transform: translateX(-50%) translateY(0);
		}
	}

	@media (max-width: 640px) {
		.company-backdrop {
			display: block;
			position: fixed;
			inset: 0;
			background: rgba(0, 0, 0, 0.5);
			opacity: 0;
			pointer-events: none;
			transition: opacity 0.2s ease;
			z-index: 30;
		}

		.company-popover {
			position: fixed;
			left: 0;
			right: 0;
			bottom: 0;
			width: auto;
			max-width: none;
			transform: translateY(100%);
			border-radius: 16px 16px 0 0;
			padding: 2rem 1.25rem calc(1.25rem + env(safe-area-inset-bottom));
			z-index: 31;
			transition: transform 0.25s ease;
			box-shadow: 0 -8px 24px rgba(0, 0, 0, 0.4);
		}

		.company-popover-arrow {
			display: none;
		}

		.company-cta {
			padding: 0.7rem 1rem;
		}

		.company-wrap.open .company-backdrop {
			opacity: 1;
			pointer-events: auto;
		}

		.company-wrap.open .company-popover {
			transform: translateY(0);
		}
	}

	.chevron {
		display: inline-block;
		color: var(--color-muted);
		font-size: 0.85em;
		transition: transform 0.15s ease;
	}

	.row.is-open .chevron {
		transform: rotate(90deg);
	}

	.description {
		margin: 0.6rem 0 0;
	}

	@media (max-width: 480px) {
		.timeline {
			grid-template-columns: 3.2rem 1.5rem 1fr;
			column-gap: 0.6rem;
		}

		.year {
			font-size: 0.8rem;
			white-space: normal;
			line-height: 1.2;
		}
	}
</style>
