---
import type { Lang } from '../../data/resume';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const t = {
  pt: { url: 'exemplo.com › produtos', score: 'SEO' },
  en: { url: 'example.com › products', score: 'SEO' },
  es: { url: 'ejemplo.com › productos', score: 'SEO' },
}[lang];
---

<div class="mockup seo-mockup" aria-hidden="true">
	<div class="score-badge">
		<span class="score-value" data-score-value>60</span>
		<span class="score-label">{t.score}</span>
	</div>
	<div class="result">
		<span class="url">{t.url}</span>
		<span class="line title" />
		<span class="line desc long" />
		<span class="line desc short" />
	</div>
	<div class="tags-row">
		<span class="meta-pill">&lt;title&gt;</span>
		<span class="meta-pill">og:image</span>
		<span class="meta-pill">sitemap.xml</span>
	</div>
</div>

<script>
	document.querySelectorAll<HTMLElement>('[data-score-value]').forEach((el) => {
		const min = 60;
		const max = 98;

		const style = getComputedStyle(el);
		const fromRgb = style.getPropertyValue('--color-selected-rgb').trim();
		const toRgb = style.getPropertyValue('--color-accent-rgb').trim();
		const [fr, fg, fb] = fromRgb.split(',').map((n) => parseFloat(n));
		const [tr, tg, tb] = toRgb.split(',').map((n) => parseFloat(n));

		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches || Number.isNaN(fr) || Number.isNaN(tr)) {
			el.textContent = String(max);
			el.style.color = `rgb(${toRgb})`;
			return;
		}

		const duration = 2000;
		const holdMs = 1800;
		const slot = el.closest<HTMLElement>('.mockup-col');
		let start: number | null = null;

		const frame = (timestamp: number) => {
			const playing = !slot || getComputedStyle(slot).getPropertyValue('--anim-play').trim() === 'running';
			if (!playing) {
				start = null;
				el.textContent = String(min);
				el.style.color = `rgb(${fromRgb})`;
				requestAnimationFrame(frame);
				return;
			}

			if (start === null) start = timestamp;
			const progress = Math.min((timestamp - start) / duration, 1);
			const value = Math.round(min + (max - min) * progress);
			const r = Math.round(fr + (tr - fr) * progress);
			const g = Math.round(fg + (tg - fg) * progress);
			const b = Math.round(fb + (tb - fb) * progress);

			el.textContent = String(value);
			el.style.color = `rgb(${r}, ${g}, ${b})`;

			if (progress < 1) {
				requestAnimationFrame(frame);
			} else {
				setTimeout(() => {
					start = null;
					requestAnimationFrame(frame);
				}, holdMs);
			}
		};

		requestAnimationFrame(frame);
	});
</script>

<style>
	.mockup {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 12px;
		padding: 1rem 1.1rem;
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
	}

	.score-badge {
		display: flex;
		align-items: baseline;
		gap: 0.35rem;
		align-self: flex-start;
		border: 2px solid var(--color-accent);
		border-radius: 999px;
		padding: 0.25rem 0.8rem;
		animation: score-glow 2.4s ease-in-out infinite;
		animation-play-state: var(--anim-play, paused);
	}

	@keyframes score-glow {
		0%,
		100% {
			box-shadow: 0 0 0 0 rgba(var(--color-accent-rgb), 0.4);
		}
		50% {
			box-shadow: 0 0 0 5px rgba(var(--color-accent-rgb), 0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.score-badge {
			animation: none;
		}
	}

	.score-value {
		font-weight: 800;
		font-size: 1.1rem;
		color: var(--color-accent);
	}

	.score-label {
		font-size: 0.65rem;
		font-weight: 700;
		color: var(--color-muted);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.result {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.url {
		font-size: 0.72rem;
		color: var(--color-muted);
	}

	.line {
		height: 8px;
		border-radius: 4px;
	}

	.line.title {
		width: 70%;
		height: 10px;
		background: var(--color-accent);
		opacity: 0.85;
	}

	.line.desc {
		background: var(--color-border);
	}

	.line.desc.long {
		width: 95%;
	}

	.line.desc.short {
		width: 65%;
	}

	.tags-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
		padding-top: 0.6rem;
		border-top: 1px dashed var(--color-border);
	}

	.meta-pill {
		font-size: 0.65rem;
		font-family: ui-monospace, 'SFMono-Regular', Menlo, monospace;
		color: var(--color-muted);
		border: 1px solid var(--color-border);
		border-radius: 6px;
		padding: 0.15rem 0.5rem;
	}
</style>
