---
import type { Lang } from '../../data/resume';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const t = {
  pt: { placeholder: 'Buscar produtos...', query: 'tênis branco', filters: ['Cashback', 'Preço', 'Categoria'] },
  en: { placeholder: 'Search products...', query: 'white sneakers', filters: ['Cashback', 'Price', 'Category'] },
  es: { placeholder: 'Buscar productos...', query: 'zapatillas blancas', filters: ['Cashback', 'Precio', 'Categoría'] },
}[lang];
---

<div class="mockup catalog-mockup" aria-hidden="true" data-catalog-mockup data-query={t.query}>
	<div class="search-bar">
		<span class="search-icon" />
		<span class="placeholder" data-placeholder>{t.placeholder}</span>
		<span class="typed" data-typed hidden></span>
		<span class="cursor" />
	</div>
	<div class="pills">
		{t.filters.map((filter) => <span class="pill">{filter}</span>)}
	</div>
	<div class="results">
		{
			Array.from({ length: 3 }).map(() => (
				<div class="result-row">
					<span class="thumb" />
					<div class="lines">
						<span class="line long" />
						<span class="line short" />
					</div>
				</div>
			))
		}
	</div>
</div>

<script>
	document.querySelectorAll<HTMLElement>('[data-catalog-mockup]').forEach((mockup) => {
		const placeholder = mockup.querySelector<HTMLElement>('[data-placeholder]');
		const typed = mockup.querySelector<HTMLElement>('[data-typed]');
		const query = mockup.dataset.query ?? '';

		if (!placeholder || !typed || !query) return;
		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

		const slot = mockup.closest<HTMLElement>('.mockup-col');
		let index = 0;
		let phase: 'idle' | 'typing' | 'pause' | 'deleting' = 'idle';
		let waitTicks = 0;

		const tick = () => {
			const playing = !slot || getComputedStyle(slot).getPropertyValue('--anim-play').trim() === 'running';
			if (!playing) {
				if (phase !== 'idle' || index !== 0) {
					phase = 'idle';
					index = 0;
					waitTicks = 0;
					placeholder.hidden = false;
					typed.hidden = true;
					typed.textContent = '';
				}
				setTimeout(tick, 200);
				return;
			}

			if (phase === 'idle') {
				waitTicks++;
				if (waitTicks >= 12) {
					waitTicks = 0;
					phase = 'typing';
					placeholder.hidden = true;
					typed.hidden = false;
				}
			} else if (phase === 'typing') {
				index++;
				typed.textContent = query.slice(0, index);
				if (index >= query.length) {
					phase = 'pause';
				}
			} else if (phase === 'pause') {
				waitTicks++;
				if (waitTicks >= 16) {
					waitTicks = 0;
					phase = 'deleting';
				}
			} else if (phase === 'deleting') {
				index--;
				typed.textContent = query.slice(0, index);
				if (index <= 0) {
					phase = 'idle';
					placeholder.hidden = false;
					typed.hidden = true;
				}
			}
			setTimeout(tick, phase === 'typing' || phase === 'deleting' ? 90 : 100);
		};

		setTimeout(tick, 100);
	});
</script>

<style>
	.mockup {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 12px;
		padding: 1rem 1.1rem;
	}

	.search-bar {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: 999px;
		padding: 0.5rem 0.9rem;
	}

	.search-icon {
		width: 0.8rem;
		height: 0.8rem;
		border: 2px solid var(--color-muted);
		border-radius: 50%;
		position: relative;
		flex-shrink: 0;
	}

	.search-icon::after {
		content: '';
		position: absolute;
		width: 0.45rem;
		height: 2px;
		background: var(--color-muted);
		bottom: -0.3rem;
		right: -0.25rem;
		transform: rotate(45deg);
	}

	.placeholder {
		font-size: 0.8rem;
		color: var(--color-muted);
	}

	.typed {
		font-size: 0.8rem;
		color: var(--color-text);
	}

	.typed[hidden] {
		display: none;
	}

	.cursor {
		width: 1px;
		height: 0.85rem;
		background: var(--color-muted);
		animation: blink 1.1s step-end infinite;
		animation-play-state: var(--anim-play, paused);
	}

	@keyframes blink {
		0%,
		45% {
			opacity: 1;
		}
		50%,
		100% {
			opacity: 0;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.cursor {
			animation: none;
		}
	}

	.pills {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin: 0.75rem 0;
	}

	.pill {
		font-size: 0.72rem;
		font-weight: 600;
		color: var(--color-muted);
		border: 1px solid var(--color-border);
		border-radius: 999px;
		padding: 0.2rem 0.7rem;
	}

	.pill:first-child {
		color: var(--color-bg);
		background: var(--color-selected);
		border-color: var(--color-selected);
	}

	.results {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		padding-top: 0.6rem;
		border-top: 1px dashed var(--color-border);
	}

	.result-row {
		display: flex;
		align-items: center;
		gap: 0.6rem;
	}

	.thumb {
		width: 2rem;
		height: 2rem;
		border-radius: 6px;
		background: var(--color-border);
		flex-shrink: 0;
	}

	.lines {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		flex: 1;
	}

	.line {
		height: 7px;
		border-radius: 4px;
		background: var(--color-border);
	}

	.line.long {
		width: 80%;
	}

	.line.short {
		width: 45%;
	}
</style>
