---
import type { Lang } from '../../data/resume';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const t = {
  pt: { json: 'json', ui: 'UI' },
  en: { json: 'json', ui: 'UI' },
  es: { json: 'json', ui: 'UI' },
}[lang];
---

<div class="mockup sdui-mockup" aria-hidden="true">
	<div class="json-col">
		<span class="tag">{t.json}</span>
		<span class="line long" />
		<span class="line short" />
		<span class="line medium" />
		<span class="line short" />
	</div>
	<span class="arrow">→</span>
	<div class="ui-col">
		<span class="tag">{t.ui}</span>
		<div class="mini-card">
			<span class="line short" />
			<span class="pill" />
		</div>
	</div>
</div>

<style>
	.mockup {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 12px;
		padding: 1rem 1.1rem;
		display: flex;
		align-items: center;
		gap: 0.6rem;
	}

	.json-col,
	.ui-col {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}

	.tag {
		font-size: 0.65rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: var(--color-muted);
	}

	.line {
		height: 6px;
		border-radius: 4px;
		background: var(--color-border);
		font-family: ui-monospace, monospace;
	}

	.line.long {
		width: 90%;
	}

	.line.medium {
		width: 65%;
	}

	.line.short {
		width: 45%;
	}

	.arrow {
		color: var(--color-accent);
		font-size: 1.1rem;
		flex-shrink: 0;
		animation: arrow-nudge 1.6s ease-in-out infinite;
		animation-play-state: var(--anim-play, paused);
	}

	@keyframes arrow-nudge {
		0%,
		100% {
			transform: translateX(0);
		}
		50% {
			transform: translateX(4px);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.arrow {
			animation: none;
		}
	}

	.mini-card {
		border: 1px solid var(--color-border);
		border-radius: 8px;
		padding: 0.5rem;
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.pill {
		width: 2.6rem;
		height: 0.9rem;
		border-radius: 999px;
		background: var(--color-accent);
	}
</style>
