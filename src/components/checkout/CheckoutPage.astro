---
import type { Lang } from '../../data/resume';
import Card from '../design-system/Card.astro';
import Badge from '../design-system/Badge.astro';
import Button from '../design-system/Button.astro';
import CardPaymentSheet from './CardPaymentSheet.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const localePrefix = { pt: '', en: '/en', es: '/es' }[lang];
const backHref = `${base}${localePrefix}/`;

const currency = { pt: 'R$', en: '$', es: '$' }[lang];
const decimal = { pt: ',', en: '.', es: ',' }[lang];
const price = (value: number) => `${currency}${value.toFixed(2).replace('.', decimal)}`;

type Product = { id: string; name: string; price: number; tag: string };

const productsByLang: Record<Lang, Product[]> = {
  pt: [
    { id: 'jacket', name: 'Jaqueta jeans', price: 259.9, tag: 'Novo' },
    { id: 'dress', name: 'Vestido floral', price: 219.9, tag: 'Best seller' },
    { id: 'sneakers', name: 'Tênis branco', price: 349.9, tag: '-10%' },
    { id: 'bag', name: 'Bolsa de couro', price: 289.9, tag: 'Edição limitada' },
  ],
  en: [
    { id: 'jacket', name: 'Denim jacket', price: 259.9, tag: 'New' },
    { id: 'dress', name: 'Floral dress', price: 219.9, tag: 'Best seller' },
    { id: 'sneakers', name: 'White sneakers', price: 349.9, tag: '-10%' },
    { id: 'bag', name: 'Leather bag', price: 289.9, tag: 'Limited run' },
  ],
  es: [
    { id: 'jacket', name: 'Chaqueta de mezclilla', price: 259.9, tag: 'Nuevo' },
    { id: 'dress', name: 'Vestido floral', price: 219.9, tag: 'Best seller' },
    { id: 'sneakers', name: 'Zapatillas blancas', price: 349.9, tag: '-10%' },
    { id: 'bag', name: 'Bolso de cuero', price: 289.9, tag: 'Edición limitada' },
  ],
};

const products = productsByLang[lang];

const t = {
  pt: {
    intro: 'Checkout de e-commerce',
    lead: 'Reconstrução do fluxo de finalização de compra: adicione itens ao carrinho e veja o total mudar ao vivo, depois abra o passo de pagamento — tudo em JavaScript puro, cliente, sem nenhum dado saindo do navegador.',
    back: '← Voltar ao portfólio',
    addLabel: 'Adicionar',
    cartHeading: 'Sacola',
    empty: 'Sua sacola está vazia. Adicione um item para continuar.',
    subtotal: 'Subtotal',
    shipping: 'Frete',
    free: 'Grátis',
    total: 'Total',
    checkout: 'Finalizar compra',
    remove: 'Remover',
    qty: 'Qtd.',
  },
  en: {
    intro: 'E-commerce checkout',
    lead: "A reconstruction of the checkout flow: add items to the bag and watch the total update live, then open the payment step — all plain client-side JavaScript, nothing ever leaves the browser.",
    back: '← Back to portfolio',
    addLabel: 'Add',
    cartHeading: 'Bag',
    empty: 'Your bag is empty. Add an item to continue.',
    subtotal: 'Subtotal',
    shipping: 'Shipping',
    free: 'Free',
    total: 'Total',
    checkout: 'Checkout',
    remove: 'Remove',
    qty: 'Qty',
  },
  es: {
    intro: 'Checkout de e-commerce',
    lead: 'Reconstrucción del flujo de finalización de compra: agrega artículos a la bolsa y mira el total cambiar en vivo, luego abre el paso de pago — todo en JavaScript puro del cliente, sin que ningún dato salga del navegador.',
    back: '← Volver al portafolio',
    addLabel: 'Agregar',
    cartHeading: 'Bolsa',
    empty: 'Tu bolsa está vacía. Agrega un artículo para continuar.',
    subtotal: 'Subtotal',
    shipping: 'Envío',
    free: 'Gratis',
    total: 'Total',
    checkout: 'Finalizar compra',
    remove: 'Quitar',
    qty: 'Cant.',
  },
}[lang];
---

<div class="section-breakout">
<div class="section-breakout-inner">
<article class="checkout-page">
	<a href={backHref} class="back-link">{t.back}</a>
	<h1>{t.intro}</h1>
	<p class="lead">{t.lead}</p>

	<div class="checkout-layout">
		<div class="product-grid">
			{
				products.map((product) => (
					<Card title={product.name}>
						<div class="product-thumb" />
						<Badge tone="accent">{product.tag}</Badge>
						<p class="price">{price(product.price)}</p>
						<Button
							variant="primary"
							data-add-to-cart
							data-product-id={product.id}
							data-product-name={product.name}
							data-product-price={product.price}
						>
							{t.addLabel}
						</Button>
					</Card>
				))
			}
		</div>

		<aside
			class="cart"
			data-cart
			data-currency={currency}
			data-decimal={decimal}
			data-remove-label={t.remove}
			aria-label={t.cartHeading}
		>
			<h2>{t.cartHeading}</h2>
			<p class="empty-message" data-cart-empty>{t.empty}</p>
			<ul class="cart-lines" data-cart-lines></ul>
			<div class="cart-totals" data-cart-totals hidden>
				<div class="row">
					<span>{t.subtotal}</span>
					<span data-cart-subtotal>{price(0)}</span>
				</div>
				<div class="row">
					<span>{t.shipping}</span>
					<span>{t.free}</span>
				</div>
				<div class="row total">
					<span>{t.total}</span>
					<span data-cart-total>{price(0)}</span>
				</div>
			</div>
			<Button variant="primary" disabled data-open-card-sheet>
				{t.checkout}
			</Button>
		</aside>
	</div>

	<CardPaymentSheet lang={lang} />
</article>
</div>
</div>

<script>
	type Line = { id: string; name: string; price: number; qty: number };

	document.querySelectorAll<HTMLElement>('[data-cart]').forEach((cartEl) => {
		const currency = cartEl.dataset.currency ?? '$';
		const decimal = cartEl.dataset.decimal ?? '.';
		const removeLabel = cartEl.dataset.removeLabel ?? 'Remove';
		const formatPrice = (value: number) => `${currency}${value.toFixed(2).replace('.', decimal)}`;

		const lines = new Map<string, Line>();
		const linesList = cartEl.querySelector<HTMLElement>('[data-cart-lines]');
		const emptyMessage = cartEl.querySelector<HTMLElement>('[data-cart-empty]');
		const totalsBlock = cartEl.querySelector<HTMLElement>('[data-cart-totals]');
		const subtotalEl = cartEl.querySelector<HTMLElement>('[data-cart-subtotal]');
		const totalEl = cartEl.querySelector<HTMLElement>('[data-cart-total]');
		const checkoutBtn = cartEl.querySelector<HTMLButtonElement>('[data-open-card-sheet]');

		const render = () => {
			if (!linesList) return;
			linesList.innerHTML = '';

			lines.forEach((line) => {
				const li = document.createElement('li');
				li.className = 'cart-line';
				li.innerHTML = `
					<span class="line-name">${line.name} <span class="line-qty">× ${line.qty}</span></span>
					<span class="line-price">${formatPrice(line.price * line.qty)}</span>
					<button type="button" class="line-remove" aria-label="${removeLabel} ${line.name}">×</button>
				`;
				li.querySelector('.line-remove')?.addEventListener('click', () => {
					const current = lines.get(line.id);
					if (!current) return;
					if (current.qty > 1) {
						current.qty -= 1;
					} else {
						lines.delete(line.id);
					}
					render();
				});
				linesList.appendChild(li);
			});

			const hasItems = lines.size > 0;
			if (emptyMessage) emptyMessage.hidden = hasItems;
			if (totalsBlock) totalsBlock.hidden = !hasItems;
			if (checkoutBtn) checkoutBtn.disabled = !hasItems;

			const total = Array.from(lines.values()).reduce((sum, line) => sum + line.price * line.qty, 0);
			if (subtotalEl) subtotalEl.textContent = formatPrice(total);
			if (totalEl) totalEl.textContent = formatPrice(total);
		};

		document.querySelectorAll<HTMLButtonElement>('[data-add-to-cart]').forEach((btn) => {
			btn.addEventListener('click', () => {
				const id = btn.dataset.productId!;
				const name = btn.dataset.productName!;
				const productPrice = parseFloat(btn.dataset.productPrice!);
				const existing = lines.get(id);
				if (existing) {
					existing.qty += 1;
				} else {
					lines.set(id, { id, name, price: productPrice, qty: 1 });
				}
				render();
			});
		});

		document.addEventListener('payment-simulated', () => {
			lines.clear();
			render();
		});

		render();
	});
</script>

<style>
	.section-breakout {
		width: 100vw;
		max-width: 100vw;
		margin-left: calc(50% - 50vw);
		margin-right: calc(50% - 50vw);
	}

	.section-breakout-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	.checkout-page {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.back-link {
		font-size: 0.9rem;
		align-self: flex-start;
	}

	h1 {
		margin: 0;
	}

	.lead {
		margin: 0;
		color: var(--color-muted);
		max-width: 40rem;
	}

	.checkout-layout {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
		align-items: start;
	}

	@media (min-width: 900px) {
		.checkout-layout {
			grid-template-columns: 1fr 20rem;
		}
	}

	.product-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.25rem;
	}

	@media (min-width: 520px) {
		.product-grid {
			grid-template-columns: repeat(4, 1fr);
		}
	}

	@media (min-width: 900px) {
		.product-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	.product-grid :global(.card) {
		max-width: none;
	}

	.product-thumb {
		width: 100%;
		aspect-ratio: 1;
		border-radius: 8px;
		border: 1px solid var(--color-border);
		background: linear-gradient(
			135deg,
			color-mix(in srgb, var(--color-accent) 30%, transparent),
			color-mix(in srgb, var(--color-accent) 8%, transparent)
		);
	}

	.price {
		margin: 0;
		font-weight: 700;
	}

	.cart {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 12px;
		padding: 1.25rem;
		position: sticky;
		top: 1rem;
	}

	.cart h2 {
		margin: 0;
		font-size: 1.05rem;
	}

	.empty-message {
		margin: 0;
		font-size: 0.85rem;
		color: var(--color-muted);
	}

	.cart-lines {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.cart-lines :global(.cart-line) {
		display: grid;
		grid-template-columns: 1fr auto auto;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.85rem;
	}

	.cart-lines :global(.line-qty) {
		color: var(--color-muted);
		font-size: 0.8rem;
	}

	.cart-lines :global(.line-price) {
		font-weight: 600;
		white-space: nowrap;
	}

	.cart-lines :global(.line-remove) {
		width: 1.5rem;
		height: 1.5rem;
		border-radius: 50%;
		border: 1px solid var(--color-border);
		background: transparent;
		color: var(--color-muted);
		cursor: pointer;
		line-height: 1;
	}

	.cart-lines :global(.line-remove:hover) {
		border-color: var(--color-selected);
		color: var(--color-selected);
	}

	.cart-totals {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		padding-top: 0.75rem;
		border-top: 1px dashed var(--color-border);
		font-size: 0.85rem;
	}

	.cart-totals .row {
		display: flex;
		justify-content: space-between;
		color: var(--color-muted);
	}

	.cart-totals .row.total {
		color: var(--color-text);
		font-weight: 700;
		font-size: 1rem;
		border-top: 1px solid var(--color-border);
		padding-top: 0.5rem;
		margin-top: 0.2rem;
	}
</style>
