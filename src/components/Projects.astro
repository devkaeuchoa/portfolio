---
import { content, type Lang } from '../data/resume';
import CheckoutMockup from './mockups/CheckoutMockup.astro';
import ProductGridMockup from './mockups/ProductGridMockup.astro';
import CatalogSearchMockup from './mockups/CatalogSearchMockup.astro';
import PublicSectorMockup from './mockups/PublicSectorMockup.astro';
import SEOMockup from './mockups/SEOMockup.astro';
import RideshareMockup from './mockups/RideshareMockup.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = content[lang];
const heading = { pt: 'Projetos', en: 'Projects', es: 'Proyectos' }[lang];
---

{t.projects.length > 0 && (
<section id="projetos" class="section-breakout">
	<div class="section-breakout-inner">
	<h2>{heading}</h2>
	<div class="projects-grid">
		{
			t.projects.map((project) => (
				<article class="entry">
					<div class="mockup-col">
						{project.mockup === 'checkout' && <CheckoutMockup lang={lang} />}
						{project.mockup === 'products' && <ProductGridMockup lang={lang} />}
						{project.mockup === 'catalog' && <CatalogSearchMockup lang={lang} />}
						{project.mockup === 'publicsector' && <PublicSectorMockup lang={lang} />}
						{project.mockup === 'seo' && <SEOMockup lang={lang} />}
						{project.mockup === 'rideshare' && <RideshareMockup lang={lang} />}
					</div>
					<div class="text-col">
						<h3>{project.name}</h3>
						{project.period && <p class="period">{project.period}</p>}
						<p class="description">{project.description}</p>
						<ul class="tags">
							{project.tags.map((tag) => <li>{tag}</li>)}
						</ul>
					</div>
				</article>
			))
		}
	</div>
	</div>
</section>
)}

<style>
	.section-breakout {
		width: 100vw;
		max-width: 100vw;
		margin-left: calc(50% - 50vw);
		margin-right: calc(50% - 50vw);
	}

	.section-breakout-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	.projects-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
		margin-top: 1.5rem;
	}

	@media (min-width: 700px) {
		.projects-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	.entry {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.mockup-col {
		width: 100%;
	}

	h3 {
		margin: 0 0 0.2rem;
		font-size: 1.05rem;
	}

	.period {
		margin: 0 0 0.4rem;
		font-size: 0.8rem;
		color: var(--color-muted);
	}

	.description {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.92rem;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		list-style: none;
		padding: 0;
		margin: 0.75rem 0 0;
	}

	.tags li {
		font-size: 0.8rem;
		color: var(--color-muted);
		border: 1px solid var(--color-border);
		border-radius: 999px;
		padding: 0.15rem 0.7rem;
	}
</style>
